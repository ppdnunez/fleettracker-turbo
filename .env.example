APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.example.com
MAIL_PORT=465
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

GEOFENCE_ALERT_EMAIL=alerts@example.com

# Shared-secret path token for the GPS file-upload webhook (POST /api/gps-upload/{token}) —
# the HTTP replacement for the FTPGPS FTP site.
GPS_UPLOAD_TOKEN=changeme

# Recipient for unregistered-driver-tap alerts (see UnregisteredDriverAlertService)
DRIVER_CHECKIN_ALERT_EMAIL=alerts@example.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_GPS_PROVIDER=turbohive

# TurboHive MQTT configuration for browser live location updates
VITE_TURBOHIVE_MQTT_URL=wss://mqtt.turbohive.ai/mqtt
VITE_TURBOHIVE_MQTT_USERNAME=turbohive
VITE_TURBOHIVE_MQTT_PASSWORD=secret
VITE_TURBOHIVE_USER_ID=10482
VITE_TURBOHIVE_MQTT_TOPIC_PREFIX=10482/location/gnss/#

# GPS provider selection: 'traccar' or 'turbohive'
GPS_PROVIDER=turbohive

# TurboHive API settings (if using turbohive provider)
# TURBOHIVE_BASE_URL defaults to https://turbohive.ai/api
TURBOHIVE_BASE_URL=https://turbohive.ai/api
TURBOHIVE_TOKEN=eyJhbGciOiJIUzI1NiJ9.eyJ1c2VyVHlwZSI6ImNsaWVudCIsInVzZXJJZCI6MTA0ODIsImVtYWlsIjoicHJvZ3JhbW1lcjAyQG5leHRnZW5wbmcubmV0Iiwic3ViIjoicHJvZ3JhbW1lcjAyQG5leHRnZW5wbmcubmV0IiwiaWF0IjoxNzgyODcwOTg5LCJleHAiOjM1NjgzMzM5Nzl9.o1rB5PIVkDRg5mSTW89ZBVFrXC_2xKRIVLHav17aqCc

# Shared-secret path token for the public face-photo upload webhook (POST /api/turbohive/face-upload/{token}).
# Point each device's UPLOADFACE URL at .../api/turbohive/face-upload/<this value>.
TURBOHIVE_FACE_UPLOAD_TOKEN=changeme

# alert.code JC171 sends on {userId}/alert/{imei} for "AFIF face check found no match" — confirmed
# 2026-07-16 from a live device push (alert.type 213). Leave unset to disable the relay-disconnect
# path entirely if you're on different firmware and haven't verified this code yourself.
TURBOHIVE_FACE_UNRECOGNIZED_ALERT_CODE=1824
# Complement: code 1823 = AFIF face check found a match. Arms the relay-reconnect path.
TURBOHIVE_FACE_RECOGNIZED_ALERT_CODE=1823
